---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";
import { getLangFromUrl } from "@/i18n/ui";

export function getStaticPaths() {
  return [
    { params: { lang: "en" } },
  ];
}

const lang = getLangFromUrl(Astro.url);


// Bilingual content
const content = {
  zh: {
    title: "关于",
    intro: "这是一个基于 AstroPaper 主题构建的双语博客系统。",
    description: "AstroPaper 是一个简洁、无障碍且对 SEO 友好的博客主题，基于 Astro 和 TailwindCSS 构建。",
    features: "功能特点",
    featureList: [
      "🌍 **双语支持** - 完整的中英文内容支持",
      "🚀 **高性能** - 基于 Astro 5 的静态站点生成",
      "🌙 **明暗模式** - 支持明暗主题切换",
      "📱 **响应式设计** - 完美适配各种设备",
      "🔍 **SEO 友好** - 内置 SEO 优化",
      "♿ **无障碍** - 遵循 WCAG 标准",
    ],
    support: "支持项目",
    supportText: "如果你喜欢这个项目，欢迎给它一个 ⭐️",
  },
  en: {
    title: "About",
    intro: "This is a bilingual blog system built on the AstroPaper theme.",
    description: "AstroPaper is a minimal, accessible and SEO-friendly Astro blog theme built with Astro and TailwindCSS.",
    features: "Features",
    featureList: [
      "🌍 **Bilingual Support** - Full Chinese and English content support",
      "🚀 **High Performance** - Built on Astro 5 static site generation",
      "🌙 **Dark Mode** - Light and dark theme toggle",
      "📱 **Responsive** - Works perfectly on all devices",
      "🔍 **SEO Friendly** - Built-in SEO optimization",
      "♿ **Accessible** - Follows WCAG standards",
    ],
    support: "Support",
    supportText: "If you like this project, please give it a ⭐️",
  },
};

const c = content[lang as keyof typeof content];
---

<Layout title={`${c.title} | ${SITE.title}`}>
  <Header lang={lang} />
  <Breadcrumb lang={lang} />
  <main id="main-content" class="app-layout">
    <section id="about" class="app-prose mb-28 max-w-app prose-img:border-0">
      <h1 class="text-2xl tracking-wider sm:text-3xl">{c.title}</h1>
      
      <p>{c.intro}</p>
      <p>{c.description}</p>
      
      <h2>{c.features}</h2>
      <ul>
        {c.featureList.map(feature => (
          <li set:html={feature.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')} />
        ))}
      </ul>
      
      <h2>{c.support}</h2>
      <p>
        {c.supportText}
        <a href="https://github.com/Wiltiness/Open-Source-Blog" target="_blank" rel="noopener noreferrer">
          GitHub
        </a>
      </p>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>

